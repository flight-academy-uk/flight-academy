{
  "openapi": "3.1.0",
  "info": {
    "title": "Flight Academy API",
    "description": "Multi-tenant aviation platform — UK CAA / EASA ATO, Part 145, airfield operator surfaces.",
    "license": {
      "name": "AGPL-3.0-only",
      "identifier": "AGPL-3.0-only"
    },
    "version": "0.1.0"
  },
  "paths": {
    "/api/v1/tenants/{tenant}": {
      "get": {
        "summary": "GET a tenant by slug. Returns the public read shape if the subject is\npermitted to see this tenant (today: TenantOwnership, i.e. the subject\nbelongs to it).",
        "operationId": "tenant_get",
        "parameters": [
          {
            "name": "tenant",
            "in": "path",
            "description": "Tenant slug per ADR-006 §C.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Tenant profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TenantResponse"
                }
              }
            }
          },
          "401": {
            "description": "No authenticated subject",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "403": {
            "description": "Subject is not a member of this tenant",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "No live tenant with that slug",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "delete": {
        "summary": "DELETE a tenant by slug — soft-delete (`deleted_at` + `deletion_reason`).\nTenant-admin only (TenantAdministration). The UPDATE and the audit\nrow commit or fail together for the same regulator-facing reason as\nPATCH.",
        "operationId": "tenant_delete",
        "parameters": [
          {
            "name": "tenant",
            "in": "path",
            "description": "Tenant slug per ADR-006 §C.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TenantDeleteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "204": {
            "description": "Tenant soft-deleted"
          },
          "400": {
            "description": "deletion_reason missing or empty",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "No authenticated subject",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "403": {
            "description": "Subject is not a tenant-admin of this tenant",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "No live tenant with that slug",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      },
      "patch": {
        "summary": "PATCH a tenant by slug. Tenant-admin only (TenantAdministration). The\nUPDATE and the audit-event INSERT run in the same SERIALIZABLE\ntransaction so they commit or fail together — see ADR-009 §A on the\nregulator-facing guarantee that every state change has a paired audit\nrow.",
        "operationId": "tenant_patch",
        "parameters": [
          {
            "name": "tenant",
            "in": "path",
            "description": "Tenant slug per ADR-006 §C.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TenantPatchRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Updated tenant profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TenantResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation failed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "No authenticated subject",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "403": {
            "description": "Subject is not a tenant-admin of this tenant",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "No live tenant with that slug",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/tenants/{tenant}/audit-events/count": {
      "get": {
        "summary": "Tenant-scoped audit-event count — the walking-skeleton round-trip that\nproves ABAC + RLS end to end. The slug → id lookup happens before\npolicy evaluation (unknown slug → 404, mismatched tenant → 403);\n`Db::begin_tenant` opens a transaction with `SET LOCAL ROLE app_api`\n+ the `app.current_tenant` GUC so the SELECT below is filtered by the\nRLS policy on `audit_events`.",
        "description": "Real audit-event browsing belongs in the staff plane (`apps/admin`,\nADR-010 §I); this counts rows for the WS#4 demonstration without\nexposing audit content.",
        "operationId": "audit_event_count",
        "parameters": [
          {
            "name": "tenant",
            "in": "path",
            "description": "Tenant slug per ADR-006 §C.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Audit-event count for the tenant",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditEventCount"
                }
              }
            }
          },
          "401": {
            "description": "No authenticated subject",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "403": {
            "description": "Subject's tenant does not match path tenant",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "404": {
            "description": "No live tenant with that slug",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/healthz": {
      "get": {
        "summary": "Liveness probe. Returned 200 means the process is running and the HTTP\nstack is responsive; readiness (DB, KMS, object store) will live behind\na separate `/readyz` per ADR-002 §G when those dependencies land.",
        "operationId": "healthz",
        "responses": {
          "200": {
            "description": "Service is up",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AuditEventCount": {
        "type": "object",
        "required": [
          "count"
        ],
        "properties": {
          "count": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "HealthResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "properties": {
          "status": {
            "type": "string"
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "description": "RFC 9457 problem+json envelope. Serde renames `type_uri` to `type` since\n`type` is a reserved Rust keyword.",
        "required": [
          "type",
          "title",
          "status"
        ],
        "properties": {
          "detail": {
            "type": [
              "string",
              "null"
            ]
          },
          "instance": {
            "type": [
              "string",
              "null"
            ]
          },
          "request_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "title": {
            "type": "string"
          },
          "type": {
            "type": "string"
          }
        }
      },
      "TenantDeleteRequest": {
        "type": "object",
        "description": "Soft-delete body for `DELETE /api/v1/tenants/{tenant}`. `deletion_reason`\nis required so every deletion carries an auditable rationale. Free-form\nstring for now; the enum form lands with the retention-rules resource.",
        "required": [
          "deletion_reason"
        ],
        "properties": {
          "deletion_reason": {
            "type": "string"
          }
        }
      },
      "TenantPatchRequest": {
        "type": "object",
        "description": "Partial-update body for `PATCH /api/v1/tenants/{tenant}`. Either field\nis optional; omitted fields are left untouched. `slug` and\n`tenant_type` are intentionally not editable — both are identity-shaped\n(URL stability, regulatory operator class) and changes deserve their\nown endpoints with separate semantics.",
        "properties": {
          "name": {
            "type": [
              "string",
              "null"
            ]
          },
          "settings": {}
        }
      },
      "TenantResponse": {
        "type": "object",
        "description": "Public read shape for a tenant. Mirrors `flight_academy_db::Tenant`\nminus internals; sensitivity-classed fields (DEK wrapping, deletion\nmetadata, etc.) are not in the wire shape per ADR-008 §B.",
        "required": [
          "id",
          "slug",
          "name",
          "tenant_type",
          "settings"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "settings": {},
          "slug": {
            "type": "string"
          },
          "tenant_type": {
            "type": "string"
          }
        }
      }
    }
  }
}
